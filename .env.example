# OpenAI API klíč (DALL-E 3)
OPENAI_API_KEY=sk-your-openai-api-key

# Port serveru (např. 3020)
PORT=3020

# PostgreSQL
DATABASE_URL=postgresql://postgres:heslo@localhost:5432/factoryshop_konfigurator
# DATABASE_SSL=true   # pro cloud DB (Railway, Neon, ...)
# MAX_GENERATIONS_PER_DAY=10

# FTP konfigurace (pro upload vygenerovaných souborů)
# Pokud není nastaveno, soubory se ukládají lokálně do /output
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_BASE_PATH=/banner-dat
FTP_BASE_URL=https://vaše-doména.cz/files

# Alternativa: lokální složka pro výstupy (použije se pokud FTP není)
OUTPUT_DIR=./output

# Replicate API (AI upscaling + vektorizace) – viz docs/REPLICATE_API_SETUP.md
# REPLICATE_API_TOKEN=r8_xxxx
# UPSCALE_AI_ENABLED=true
